# PostgreSQL
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_PORT=5432
IDENTITY_DATABASE_URL=postgresql+psycopg2://app:app@localhost:5432/app
IDENTITY_DATABASE_SCHEMA=identity
IDENTITY_PORT=8100
BACKEND_DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/app
BACKEND_DATABASE_SCHEMA=backend
BACKEND_PORT=8200
BACKEND_JWT_SECRET=replace-with-a-long-random-secret
BACKEND_JWT_ALGORITHM=HS256
BACKEND_RABBITMQ_URL=amqp://app:app@rabbitmq:5672/app
BACKEND_REQUEST_QUEUE=agent.requests
BACKEND_REPLY_QUEUE=agent.replies
BACKEND_STREAM_TIMEOUT_SECONDS=120
BACKEND_RECENT_MESSAGES_LIMIT=20
BACKEND_FRONTEND_ORIGIN=http://localhost:5173
BACKEND_DEMO_PASSWORD=demo
BACKEND_LITELLM_URL=http://litellm:4000
BACKEND_LITELLM_MODEL=openai/gpt-4o-mini
BACKEND_EMBEDDING_MODEL=kb-embedding
BACKEND_CHROMA_URL=http://chroma:8000
BACKEND_CHROMA_COLLECTION=banking_knowledge_base_v1
BACKEND_KB_MAX_FILE_SIZE_BYTES=10485760
# Agents
AGENTS_RABBITMQ_URL=amqp://app:app@rabbitmq:5672/app
AGENTS_REQUEST_QUEUE=agent.requests
AGENTS_REPLY_QUEUE=agent.replies
AGENTS_IDENTITY_BASE_URL=http://identity:8100
AGENTS_IDENTITY_TIMEOUT_SECONDS=10
AGENTS_MCP_URL=http://mcp-proxy:8400/mcp
AGENTS_MCP_TIMEOUT_SECONDS=20
AGENTS_LITELLM_URL=http://litellm:4000
AGENTS_EMBEDDING_MODEL=kb-embedding
AGENTS_EMBEDDING_DIMENSIONS=768
AGENTS_CHROMA_URL=http://chroma:8000
AGENTS_CHROMA_COLLECTION=banking_knowledge_base_v1
AGENTS_CHROMA_TENANT=default_tenant
AGENTS_CHROMA_DATABASE=default_database
AGENTS_RETRIEVAL_RESULTS_LIMIT=3
AGENTS_RESPONSE_CHUNK_SIZE=140
# Banking API
BANKING_API_DATABASE_URL=postgresql+psycopg2://app:app@localhost:5432/app
BANKING_API_DATABASE_SCHEMA=banking_api
BANKING_API_PORT=8300
# MCP Proxy
MCP_BANKING_API_BASE_URL=http://banking-api:8300
MCP_REQUEST_TIMEOUT_SECONDS=10
MCP_PORT=8400
# Frontend
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:8200
# RabbitMQ
RABBITMQ_USER=app
RABBITMQ_PASSWORD=app
RABBITMQ_VHOST=app
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
# Chroma
CHROMA_PORT=8000
# LiteLLM
LITELLM_PORT=4000
LITELLM_MASTER_KEY=sk-local-development
LITELLM_MODEL=openai/gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_API_BASE=http://host.docker.internal:11434
# Observability / SigNoz
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_DEPLOYMENT_ENVIRONMENT=local
OTEL_SDK_DISABLED=false
SIGNOZ_UI_PORT=3301
SIGNOZ_OTLP_GRPC_PORT=4317
SIGNOZ_OTLP_HTTP_PORT=4318
